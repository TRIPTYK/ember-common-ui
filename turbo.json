{
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "inputs": ["src/**"],
        "outputs": ["dist/**"]
      },
      "build:watch": {
        "persistent": true,
        "cache": false
      },
      "_syncPnpm": {
        "dependsOn": ["^build"],
        "cache": false
      },
      "build:clean": {
        "cache": false
      },
      "lint": {
        "dependsOn": ["_syncPnpm"]
      },
      "lint:fix": {
        "dependsOn": ["_syncPnpm"]
      },
      "test": {
        "dependsOn": ["_syncPnpm"]
      },
      "start": {
        "dependsOn": ["_syncPnpm"],
        "persistent": true,
        "cache": false
      }
    }
  }