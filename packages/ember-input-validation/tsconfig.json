{
  "extends": "@tsconfig/ember/tsconfig.json",
  "include": [
    "src/**/*",
    "unpublished-development-types/**/*"
  ],

  "compilerOptions": {
    "skipLibCheck": true,
    "allowJs": true,
    "declarationDir": "declarations",
    "declarationMap": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true
  }
}
