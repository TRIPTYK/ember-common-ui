      "./components/prefabs/tpk-validation-errors.js": "./dist/_app_/components/prefabs/tpk-validation-errors.js",
      "./components/prefabs/tpk-validation-file-list.js": "./dist/_app_/components/prefabs/tpk-validation-file-list.js",
      "./components/prefabs/tpk-validation-file.js": "./dist/_app_/components/prefabs/tpk-validation-file.js",
      "./components/prefabs/tpk-validation-iban.js": "./dist/_app_/components/prefabs/tpk-validation-iban.js",
      "./components/prefabs/tpk-validation-input.js": "./dist/_app_/components/prefabs/tpk-validation-input.js",
      "./components/prefabs/tpk-validation-integer.js": "./dist/_app_/components/prefabs/tpk-validation-integer.js",
      "./components/prefabs/tpk-validation-mobile.js": "./dist/_app_/components/prefabs/tpk-validation-mobile.js",
      "./components/prefabs/tpk-validation-national-number.js": "./dist/_app_/components/prefabs/tpk-validation-national-number.js",
      "./components/prefabs/tpk-validation-number.js": "./dist/_app_/components/prefabs/tpk-validation-number.js",
      "./components/prefabs/tpk-validation-password.js": "./dist/_app_/components/prefabs/tpk-validation-password.js",
      "./components/prefabs/tpk-validation-radio-group.js": "./dist/_app_/components/prefabs/tpk-validation-radio-group.js",
      "./components/prefabs/tpk-validation-radio.js": "./dist/_app_/components/prefabs/tpk-validation-radio.js",
      "./components/prefabs/tpk-validation-select-create.js": "./dist/_app_/components/prefabs/tpk-validation-select-create.js",
      "./components/prefabs/tpk-validation-select-search.js": "./dist/_app_/components/prefabs/tpk-validation-select-search.js",
      "./components/prefabs/tpk-validation-select.js": "./dist/_app_/components/prefabs/tpk-validation-select.js",
      "./components/prefabs/tpk-validation-textarea.js": "./dist/_app_/components/prefabs/tpk-validation-textarea.js",
      "./components/prefabs/tpk-validation-timepicker.js": "./dist/_app_/components/prefabs/tpk-validation-timepicker.js",
      "./components/prefabs/tpk-validation-vat.js": "./dist/_app_/components/prefabs/tpk-validation-vat.js",
      "./components/tpk-form.js": "./dist/_app_/components/tpk-form.js",
      "./components/tpk-validation-checkbox.js": "./dist/_app_/components/tpk-validation-checkbox.js",
      "./components/tpk-validation-datepicker.js": "./dist/_app_/components/tpk-validation-datepicker.js",
      "./components/tpk-validation-file.js": "./dist/_app_/components/tpk-validation-file.js",
      "./components/tpk-validation-input.js": "./dist/_app_/components/tpk-validation-input.js",
      "./components/tpk-validation-radio-group.js": "./dist/_app_/components/tpk-validation-radio-group.js",
      "./components/tpk-validation-radio.js": "./dist/_app_/components/tpk-validation-radio.js",
      "./components/tpk-validation-select.js": "./dist/_app_/components/tpk-validation-select.js",
      "./components/tpk-validation-textarea.js": "./dist/_app_/components/tpk-validation-textarea.js",
      "./modifiers/scroll-on-error.js": "./dist/_app_/modifiers/scroll-on-error.js",
      "./services/tpk-form.js": "./dist/_app_/services/tpk-form.js"
    }
  },
  "peerDependencies": {
    "@triptyk/ember-input": "workspace:*",
    "ember-immer-changeset": "^1.0.2",
    "ember-source": ">=5.0.0"
  },
  "gitHead": "0e3c997a40d084fa5eb05fe7cfd042bda3de4789"
}
